# ──────────────────────────────────────────────────────────────
# Orchor — Skill Layer for AI Agents, powered by Injective
# Copy to .env (and on Vercel set as project env vars).
# NEVER commit a real PRIVATE_KEY.
# ──────────────────────────────────────────────────────────────

# Hardhat (server-side, ONLY needed if you deploy / interact with the
# contract from local scripts). Vercel does NOT need any PRIVATE_KEY at all
# — the frontend only reads & sends user-signed transactions.

# Injective Testnet (native EVM / MultiVM) — active production chain.
# See src/lib/chain.ts `activeChain`.
INJECTIVE_TESTNET_RPC_URL=https://k8s.testnet.json-rpc.injective.network/
INJECTIVE_PRIVATE_KEY=
NEXT_PUBLIC_INJECTIVE_TESTNET_RPC=https://k8s.testnet.json-rpc.injective.network/

# OrchorCore — current production contract on Injective Testnet
NEXT_PUBLIC_ORCHOR_CORE_ADDRESS=0x26129909CFEA99D0c5D17d93090B8D36179C96d3

# Monad Testnet — legacy chain, kept for rollback only
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
PRIVATE_KEY=
NEXT_PUBLIC_ORCHOR_CORE_ADDRESS_MONAD_LEGACY=0x769fC7dFf74502E5A387eE7EF47A01917A847a03
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# Legacy SkillFlow contract (kept for backwards compat; safe to omit)
NEXT_PUBLIC_SKILLFLOW_CONTRACT_ADDRESS=

# WalletConnect — get a free Project ID at https://cloud.reown.com
# Required for mobile QR + multi-wallet support via RainbowKit.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional — only used if/when /api/workflow is wired to real LLM
OPENAI_API_KEY=
