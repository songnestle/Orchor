# ──────────────────────────────────────────────────────────────
# Orchor — Skill Layer for AI Agents on Monad
# Copy to .env (and on Vercel set as project env vars).
# NEVER commit a real PRIVATE_KEY.
# ──────────────────────────────────────────────────────────────

# Hardhat (server-side, ONLY needed if you deploy / interact with the
# contract from local scripts). Vercel does NOT need PRIVATE_KEY at all
# — the frontend only reads & sends user-signed transactions.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
PRIVATE_KEY=

# OrchorCore — current production contract on Monad Testnet
NEXT_PUBLIC_ORCHOR_CORE_ADDRESS=0x769fC7dFf74502E5A387eE7EF47A01917A847a03

# Legacy SkillFlow contract (kept for backwards compat; safe to omit)
NEXT_PUBLIC_SKILLFLOW_CONTRACT_ADDRESS=

# Public RPC for browser reads
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# WalletConnect — get a free Project ID at https://cloud.reown.com
# Required for mobile QR + multi-wallet support via RainbowKit.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional — only used if/when /api/workflow is wired to real LLM
OPENAI_API_KEY=
